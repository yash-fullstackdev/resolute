# ── Database ───────────────────────────────────────────────────────────────────
# TimescaleDB (PostgreSQL) credentials and connection string
DB_USER=options
DB_PASSWORD=                   # Strong random password — generate: openssl rand -base64 24
DB_NAME=options_db
DATABASE_URL=postgresql://options:${DB_PASSWORD}@timescaledb:5432/options_db

# ── NATS ───────────────────────────────────────────────────────────────────────
# JetStream-enabled NATS for inter-service messaging
NATS_URL=nats://nats:4222

# ── Redis ──────────────────────────────────────────────────────────────────────
# Used for JWT jti blacklist, email verification tokens, override cooldown timers
REDIS_URL=redis://redis:6379/0

# ── Auth & Security ────────────────────────────────────────────────────────────
# 64-char random hex — signs user access & refresh JWTs
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# 64-char random hex — signs admin JWTs (must be different from JWT_SECRET)
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_JWT_SECRET=

# 32-byte hex (64 chars) — AES-256 key for encrypting stored broker credentials
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
CREDENTIAL_MASTER_KEY=

# Shared secret for service-to-service calls (user_worker_pool / order_router -> auth_service)
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
AUTH_INTERNAL_TOKEN=

# ── Email (for registration / password reset) ──────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=                 # SendGrid API key or SMTP password
FROM_EMAIL=noreply@yourplatform.com
FRONTEND_URL=https://app.yourplatform.com   # Used in email verification links

# ── Platform feed account (for market data — NOT a user trading account) ───────
# This is a single Dhan/Zerodha account used only to subscribe to WebSocket feeds.
# Supported brokers: dhan | zerodha | paper
FEED_BROKER=dhan
FEED_CLIENT_ID=
FEED_ACCESS_TOKEN=             # Refreshed daily; consider automating with TOTP

# ── Platform defaults ──────────────────────────────────────────────────────────
# Current RBI repo rate — update when RBI changes the rate
RBI_REPO_RATE=6.5

# ── Discipline defaults (overridable per-user in their trading plan) ───────────
PLAN_LOCK_TIME_IST=09:10       # Auto-lock daily plan at this time
PLAN_UNLOCK_TIME_IST=15:35     # Earliest time plan can be unlocked
OVERRIDE_COOLDOWN_SECONDS=60   # Mandatory wait before override confirmation
DEFAULT_DAILY_LOSS_LIMIT_INR=5000
DEFAULT_MAX_TRADES_PER_DAY=5

# ── Optional: Notifications ────────────────────────────────────────────────────
# Platform-wide Telegram alerts (not per-user)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALERT_CHAT_ID=
